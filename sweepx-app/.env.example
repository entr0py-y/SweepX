# ─── SweepX Environment Variables ────────────────────────────────────────────
# Copy this file to .env.local and fill in your credentials.
# Never commit .env.local to version control.

# ── Supabase ─────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# ── Cloudinary ───────────────────────────────────────────────────────────────
# Found in: Cloudinary Dashboard → Settings → Upload → Upload presets
# Create an UNSIGNED upload preset and paste its name below.
VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name
VITE_CLOUDINARY_UPLOAD_PRESET=your-unsigned-preset-name

# ── Roboflow ─────────────────────────────────────────────────────────────────
# Found in: Roboflow Dashboard → Account → Roboflow API
# Model format: "workspace/model-id/version"  e.g. "my-org/garbage-detection-3/1"
VITE_ROBOFLOW_API_KEY=your-roboflow-api-key
VITE_ROBOFLOW_MODEL=garbage-detection-3/1

# ─── Notes ────────────────────────────────────────────────────────────────────
# All env vars are OPTIONAL in development.
# When not set, the app runs in offline mock mode:
#   - Supabase writes are skipped (sessions stored locally)
#   - Cloudinary uploads return local object URLs
#   - Roboflow detection returns seeded mock counts
#
# This lets you develop and test the full UI flow without any external accounts.
